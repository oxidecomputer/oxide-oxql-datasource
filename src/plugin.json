{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Oxide OxQL",
  "id": "oxide-oxql-datasource",
  "metrics": true,
  "info": {
    "description": "Query and visualize metrics from an Oxide rack using OxQL.",
    "author": {
      "name": "Oxide",
      "url": "https://oxide.computer"
    },
    "keywords": ["datasource", "oxide", "oxql", "metrics", "timeseries"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      { "name": "Source", "url": "https://github.com/oxidecomputer/oxide-oxql-datasource" },
      { "name": "OxQL Documentation", "url": "https://docs.oxide.computer/guides/metrics/oxql-tutorial" },
      { "name": "Oxide", "url": "https://oxide.computer" }
    ],
    "screenshots": [{ "name": "Explore", "path": "img/explore.png" }],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  },
  "routes": [
    {
      "path": "/v1",
      "url": "{{ .JsonData.host }}",
      "headers": [
        {
          "name": "Authorization",
          "content": "Bearer {{ .SecureJsonData.apiKey }}"
        }
      ]
    }
  ]
}
